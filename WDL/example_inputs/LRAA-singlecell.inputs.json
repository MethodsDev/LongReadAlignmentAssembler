{
    "LRAA_singlecell_wf.HiFi":true,
    "LRAA_singlecell_wf.docker":"us-central1-docker.pkg.dev/methods-dev-lab/lraa/lraa:latest",

    // ref-guided mode
    "LRAA_singlecell_wf.sample_id":"${this.sample_id}",
    "LRAA_singlecell_wf.initial_annot_gtf":"gs://mdl-refs/GRCh38/GTEx_Resources_GENCODE47/human.refdata-gex-GRCh38-GENCODE47.gtf",
    "LRAA_singlecell_wf.inputBAM":"${this.inputBAM}",
    "LRAA_singlecell_wf.referenceGenome":"${this.referenceGenome}",
    
    "LRAA_singlecell_wf.main_chromosomes":"chr1 chr2 chr3 chr4 chr5 chr6 chr7 chr8 chr9 chr10 chr11 chr12 chr13 chr14 chr15 chr16 chr17 chr18 chr19 chr20 chr21 chr22 chrX chrY chrM",
    "LRAA_singlecell_wf.oversimplify":"chrM",
    "LRAA_singlecell_wf.ref_annot_gtf_source_gene_symbols":"gs://mdl-refs/GRCh38/GTEx_Resources_GENCODE47/human.refdata-gex-GRCh38-GENCODE47.gtf",

    // cell cluster-guided mode
    "LRAA_singlecell_wf.single_cell_pipe_mode":"cluster-guided"
}

